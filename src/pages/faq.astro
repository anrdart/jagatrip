---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav       from '../components/layout/Nav.astro';
import Footer    from '../components/layout/Footer.astro';
import FloatingWA from '../components/layout/FloatingWA.astro';
import { getCollection } from 'astro:content';
import { SITE, waLink }  from '../data/site';
import { faqPageSchema }    from '../data/schemas/faqPage';
import { breadcrumbSchema } from '../data/schemas/breadcrumb';

const allFaqs = await getCollection('faqs');
const sorted  = allFaqs.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { key: 'semua',        label: 'Semua' },
  { key: 'umum',         label: 'Umum' },
  { key: 'pendaftaran',  label: 'Pendaftaran' },
  { key: 'paket',        label: 'Paket' },
  { key: 'pembayaran',   label: 'Pembayaran' },
  { key: 'persiapan',    label: 'Persiapan' },
  { key: 'kebijakan',    label: 'Kebijakan' },
];

const extraSchemas = [
  faqPageSchema(sorted.map(f => ({ question: f.data.question, answer: f.data.answer }))),
  breadcrumbSchema([{ name: 'FAQ', url: `${SITE.url}/faq` }]),
];
---
<BaseLayout
  title="FAQ JAGATRIP — Pertanyaan Umum Program Edu-Tourism"
  description="Temukan jawaban atas pertanyaan umum tentang program JAGATRIP Insider Series 2026: pendaftaran, paket, pembayaran, persiapan, dan kebijakan."
  extraSchemas={extraSchemas}
>
  <Nav />
  <main id="main">

    <!-- Hero -->
    <section style="background:var(--color-ink); padding:80px 0; position:relative; overflow:hidden;">
      <div style="position:absolute; top:-50%; right:-10%; width:600px; height:600px; background:radial-gradient(circle, rgba(255,107,53,0.1) 0%, transparent 70%); pointer-events:none;"></div>
      <div class="container" style="text-align:center; position:relative; z-index:1;">
        <span class="eyebrow" style="color:var(--color-orange);">BANTUAN</span>
        <h1 class="section-title" style="color:white; margin-top:8px; font-size:clamp(36px,6vw,64px); font-weight:900;">
          Pertanyaan yang <span class="italic" style="color:var(--color-orange);">Sering Ditanyakan</span>
        </h1>
        <p style="font-size:17px; color:rgba(255,255,255,0.7); max-width:560px; margin:16px auto 0; line-height:1.7;">
          Tidak menemukan jawaban yang kamu cari? Langsung hubungi kami via WhatsApp.
        </p>
      </div>
    </section>

    <!-- FAQ content -->
    <section class="section" style="background:var(--color-white);">
      <div class="container" style="max-width:860px; margin:0 auto;">

        <!-- Category filter -->
        <div
          id="faq-filter"
          style="display:flex; flex-wrap:wrap; gap:10px; margin-bottom:48px;"
          role="tablist"
          aria-label="Filter FAQ berdasarkan kategori"
        >
          {categories.map((cat) => (
            <button
              data-filter={cat.key}
              role="tab"
              aria-selected={cat.key === 'semua' ? 'true' : 'false'}
              style="
                padding:8px 20px;
                border-radius:100px;
                border:2px solid var(--color-grey-light);
                background:white;
                font-family:var(--font-body);
                font-size:14px;
                font-weight:600;
                color:var(--color-grey);
                cursor:pointer;
                transition:all 0.2s;
              "
              class={cat.key === 'semua' ? 'filter-active' : ''}
            >
              {cat.label}
            </button>
          ))}
        </div>

        <!-- FAQ list -->
        <div id="faq-list">
          {sorted.map((faq) => (
            <div
              class="faq-item"
              data-category={faq.data.category}
              id={faq.data.id}
            >
              <button
                class="faq-question"
                aria-expanded="false"
                aria-controls={`answer-${faq.data.id}`}
              >
                <span>{faq.data.question}</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </button>
              <div
                class="faq-answer"
                id={`answer-${faq.data.id}`}
                role="region"
                aria-labelledby={faq.data.id}
              >
                <p>{faq.data.answer}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div style="text-align:center; margin-top:64px; padding:40px; background:var(--color-paper); border-radius:24px;">
          <p style="font-family:var(--font-display); font-size:20px; font-weight:700; color:var(--color-ink); margin-bottom:8px;">
            Masih ada pertanyaan lain?
          </p>
          <p style="color:var(--color-grey); font-size:15px; margin-bottom:24px;">
            Tim admin JAGATRIP siap membantu kamu langsung via WhatsApp.
          </p>
          <a href={waLink()} target="_blank" rel="noopener noreferrer" class="btn btn-wa btn-lg">
            <span aria-hidden="true">💬</span> Chat WhatsApp Sekarang
          </a>
        </div>

      </div>
    </section>

  </main>
  <Footer />
  <FloatingWA />
</BaseLayout>

<style>
  .filter-active {
    background: var(--color-orange) !important;
    color: white !important;
    border-color: var(--color-orange) !important;
  }
</style>

<script>
  import { initFaqToggle } from '../lib/faq-toggle';
  document.addEventListener('DOMContentLoaded', initFaqToggle);

  // Category filter
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const faqItems   = document.querySelectorAll<HTMLElement>('[data-category]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      filterBtns.forEach((b) => {
        b.classList.remove('filter-active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('filter-active');
      btn.setAttribute('aria-selected', 'true');

      faqItems.forEach((item) => {
        const cat = item.dataset.category!;
        item.style.display = (filter === 'semua' || cat === filter) ? 'block' : 'none';
      });
    });
  });
</script>
