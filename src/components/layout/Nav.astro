---
import Logo from '../brand/Logo.astro';
import { SITE, waLink } from '../../data/site';

const navLinks = [
  { label: 'Beranda',    href: '/' },
  { label: 'Agenda 2026', href: '/#agenda' },
  { label: 'Tentang',    href: '/tentang' },
  { label: 'FAQ',        href: '/faq' },
  { label: 'Kontak',     href: '/kontak' },
];

const currentPath = Astro.url.pathname;
---
<header class="nav" role="banner">
  <div class="container">
    <nav
      aria-label="Navigasi utama"
      style="display:flex; align-items:center; justify-content:space-between; height:68px;"
    >
      <!-- Logo -->
      <a href="/" aria-label="JAGATRIP — kembali ke beranda" style="display:flex; align-items:center; flex-shrink:0;">
        <Logo variant="horizontal" height={36} />
      </a>

      <!-- Desktop links -->
      <ul
        class="list-none"
        style="display:flex; align-items:center; gap:32px;"
        aria-label="Menu utama"
        id="desktop-nav"
      >
        {navLinks.map((link) => {
          const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href.replace('/#agenda',''));
          return (
            <li>
              <a
                href={link.href}
                aria-current={isActive ? 'page' : undefined}
                style={`
                  font-family: var(--font-body);
                  font-size: 14px;
                  font-weight: 600;
                  color: ${isActive ? 'var(--color-orange)' : 'var(--color-ink)'};
                  text-decoration: none;
                  transition: color 0.2s;
                  white-space: nowrap;
                `}
                onmouseover="this.style.color='var(--color-orange)'"
                onmouseout={`this.style.color='${isActive ? 'var(--color-orange)' : 'var(--color-ink)'}'`}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>

      <!-- CTA -->
      <div style="display:flex; align-items:center; gap:12px; flex-shrink:0;">
        <a
          href={waLink()}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-sm"
          style="box-shadow: var(--shadow-nav-cta);"
          aria-label="Daftar via WhatsApp"
        >
          <span aria-hidden="true">💬</span> Daftar Sekarang
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Buka menu navigasi"
          style="
            display:none;
            background:none;
            border:none;
            cursor:pointer;
            padding:8px;
            color:var(--color-ink);
          "
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6"  x2="21" y2="6"  />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menu navigasi mobile"
  style="
    position:fixed; inset:0; z-index:200;
    background:rgba(0,0,0,0.5);
    backdrop-filter:blur(4px);
  "
>
  <div style="
    position:absolute; top:0; right:0; bottom:0; width:280px; max-width:90vw;
    background:white;
    padding:24px;
    display:flex; flex-direction:column; gap:8px;
    overflow-y:auto;
  ">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
      <Logo variant="horizontal" height={32} />
      <button
        id="mobile-menu-close"
        aria-label="Tutup menu"
        style="background:none; border:none; cursor:pointer; padding:8px; color:var(--color-ink);"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
    {navLinks.map((link) => (
      <a
        href={link.href}
        style="
          display:block;
          padding:14px 16px;
          font-family:var(--font-body);
          font-size:16px;
          font-weight:600;
          color:var(--color-ink);
          text-decoration:none;
          border-radius:12px;
          transition:background 0.2s, color 0.2s;
        "
        onmouseover="this.style.background='var(--color-orange-light)'; this.style.color='var(--color-orange)';"
        onmouseout="this.style.background=''; this.style.color='var(--color-ink)';"
      >
        {link.label}
      </a>
    ))}
    <a
      href={waLink()}
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-wa"
      style="margin-top:16px; justify-content:center;"
    >
      <span aria-hidden="true">💬</span> Daftar via WhatsApp
    </a>
  </div>
</div>

<style>
  @media (max-width: 768px) {
    #desktop-nav { display: none !important; }
    #mobile-menu-btn { display: flex !important; }
  }
</style>

<script>
  import { initMobileMenu } from '../../lib/mobile-menu';
  initMobileMenu();
</script>
