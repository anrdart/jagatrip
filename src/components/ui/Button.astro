---
interface Props {
  href?:    string;
  variant?: 'primary' | 'secondary' | 'wa';
  size?:    'sm' | 'md' | 'lg';
  target?:  string;
  rel?:     string;
  type?:    'button' | 'submit';
  class?:   string;
  ariaLabel?: string;
}
const {
  href,
  variant  = 'primary',
  size     = 'md',
  target,
  rel,
  type     = 'button',
  class: cls = '',
  ariaLabel,
} = Astro.props;

const cls_ = ['btn', `btn-${variant}`, size !== 'md' ? `btn-${size}` : '', cls].filter(Boolean).join(' ');
---
{href ? (
  <a href={href} class={cls_} target={target} rel={rel} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={cls_} aria-label={ariaLabel}>
    <slot />
  </button>
)}
