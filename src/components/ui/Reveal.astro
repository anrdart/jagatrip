---
interface Props {
  delay?: number;
  class?: string;
  as?:    string;
}
const { delay = 0, class: cls = '', as: Tag = 'div' } = Astro.props;
---
<Tag
  class={`reveal ${cls}`}
  style={delay ? `transition-delay:${delay}ms` : ''}
>
  <slot />
</Tag>

<script>
  import { initReveal } from '../../lib/reveal';
  document.addEventListener('DOMContentLoaded', initReveal);
</script>
