---
import { formatIDRShort, formatDateRange } from '../../../lib/format';
import { waLink } from '../../../data/site';

interface Props {
  destination: string;
  titleHighlight: string;
  subtitle: string;
  lead: string;
  flag: string;
  duration: string;
  dateStart: Date;
  dateEnd: Date;
  category: string;
  earlyBirdPrice?: number;
  normalPrice?: number;
  status: 'open' | 'limited' | 'soldout' | 'tba';
  slug: string;
}

const {
  destination,
  titleHighlight,
  subtitle,
  lead,
  flag,
  duration,
  dateStart,
  dateEnd,
  category,
  earlyBirdPrice,
  normalPrice,
  status,
  slug,
} = Astro.props;

const dateRangeFormatted = formatDateRange(dateStart, dateEnd);
const waHref = waLink(destination, dateRangeFormatted);
const dateStartISO = dateStart.toISOString().split('T')[0];
const dateEndISO = dateEnd.toISOString().split('T')[0];
---

<section
  class="section glow-orange-topright"
  style="background: var(--color-paper); position: relative; overflow: hidden;"
  aria-label={`Hero: JAGATRIP to ${destination}`}
>
  <div class="container">
    <div class="hero-grid">
      <!-- Left: Text content -->
      <div class="hero-text">
        <!-- Badge -->
        <div class="hero-badge" role="note">
          <span class="pulse-dot" aria-hidden="true"></span>
          JAGATRIP INSIDER SERIES 2026 · {category.toUpperCase()}
        </div>

        <!-- H1 -->
        <h1 class="hero-h1">
          JAGATRIP TO <span class="highlight">{titleHighlight}</span>
        </h1>

        <!-- Subtitle -->
        <p class="hero-subtitle">{subtitle}</p>

        <!-- Lead -->
        <p class="hero-lead">{lead}</p>

        <!-- CTA buttons -->
        <div class="hero-ctas">
          <a href={waHref} class="btn btn-wa btn-lg" target="_blank" rel="noopener noreferrer">
            Daftar via WhatsApp <span aria-hidden="true">💬</span>
          </a>
          <a href="#itinerary" class="btn btn-secondary btn-lg">
            Lihat Itinerary →
          </a>
        </div>

        <!-- Trust row -->
        <div class="trust-row" role="list" aria-label="Informasi program">
          <div class="trust-item" role="listitem">
            <span aria-hidden="true">🗓️</span>
            <span>{duration}</span>
          </div>
          <span class="trust-divider" aria-hidden="true">·</span>
          <div class="trust-item" role="listitem">
            <time datetime={dateStartISO}>{dateRangeFormatted}</time>
          </div>
          <span class="trust-divider" aria-hidden="true">·</span>
          <div class="trust-item" role="listitem">
            <span aria-hidden="true">⚡</span>
            <span>Seat Terbatas</span>
          </div>
        </div>
      </div>

      <!-- Right: Cards -->
      <div class="hero-cards">
        <!-- Card 1: Trip info card (orange gradient) -->
        <div class="hero-card hero-card-orange" role="complementary" aria-label="Informasi trip">
          <div class="hero-card-flag" aria-hidden="true">{flag}</div>
          <h2 class="hero-card-dest">
            {destination}
          </h2>
          <div class="hero-card-meta">
            <time datetime={dateStartISO}>{dateRangeFormatted}</time>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span>{duration}</span>
          </div>

          {status === 'open' && earlyBirdPrice ? (
            <div class="hero-card-price">
              <div class="price-label">Early Bird</div>
              <div class="price-amount-hero">{formatIDRShort(earlyBirdPrice)}</div>
              <div class="price-per">per orang</div>
            </div>
          ) : status === 'limited' && earlyBirdPrice ? (
            <div class="hero-card-price">
              <div class="price-label">🔥 Kursi Terbatas!</div>
              <div class="price-amount-hero">{formatIDRShort(earlyBirdPrice)}</div>
              <div class="price-per">per orang</div>
            </div>
          ) : (
            <div class="hero-card-tba">
              Harga TBA — Hubungi WhatsApp
            </div>
          )}
        </div>

        <!-- Card 2: Social proof card (white) -->
        <div class="hero-card hero-card-white" role="complementary" aria-label="Peserta yang sudah daftar">
          <div class="avatar-stack" aria-hidden="true">
            <div class="avatar" style="background: var(--color-grad-avatar-1);">BH</div>
            <div class="avatar" style="background: var(--color-grad-avatar-2);">SR</div>
            <div class="avatar" style="background: var(--color-grad-avatar-3);">AF</div>
            <div class="avatar" style="background: var(--color-grad-avatar-4);">+</div>
          </div>
          <p class="social-proof-text">
            <strong>47+</strong> praktisi daftar
          </p>
          <p class="social-proof-sub">Daftar sekarang sebelum penuh!</p>
          <a href={waHref} class="btn btn-primary btn-sm" target="_blank" rel="noopener noreferrer">
            Amankan Kursi →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 64px;
    align-items: center;
    min-height: 80vh;
    padding-block: 80px;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-subtitle {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    font-style: italic;
    color: var(--color-orange);
    margin-top: 16px;
    margin-bottom: 20px;
    line-height: 1.4;
  }

  .hero-lead {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--color-grey);
    margin-bottom: 36px;
    max-width: 540px;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }

  .trust-row {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .trust-divider {
    color: var(--color-grey-light);
    font-size: 18px;
  }

  /* Cards column */
  .hero-cards {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .hero-card {
    border-radius: var(--radius-card);
    padding: 32px;
    box-shadow: var(--shadow-hero-card);
  }

  /* Orange card */
  .hero-card-orange {
    background: var(--color-grad-hero-card);
    color: white;
  }

  .hero-card-flag {
    font-size: 40px;
    line-height: 1;
    margin-bottom: 12px;
  }

  .hero-card-dest {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 900;
    color: white;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .hero-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: 14px;
    color: rgba(255,255,255,0.8);
    margin-bottom: 20px;
  }

  .meta-sep {
    opacity: 0.5;
  }

  .hero-card-price {
    background: rgba(0,0,0,0.15);
    border-radius: var(--radius-input);
    padding: 16px 20px;
  }

  .price-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    margin-bottom: 4px;
  }

  .price-amount-hero {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 900;
    font-style: italic;
    color: white;
    line-height: 1.1;
  }

  .price-per {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    margin-top: 4px;
  }

  .hero-card-tba {
    background: rgba(0,0,0,0.15);
    border-radius: var(--radius-input);
    padding: 16px 20px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    text-align: center;
  }

  /* White card */
  .hero-card-white {
    background: var(--color-white);
    border: 1px solid var(--color-grey-light);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .social-proof-text {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-ink);
    margin: 0;
  }

  .social-proof-text strong {
    color: var(--color-orange);
  }

  .social-proof-sub {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 380px;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-block: 60px;
      min-height: auto;
    }

    .hero-cards {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .hero-card {
      flex: 1;
      min-width: 280px;
    }

    .hero-ctas {
      flex-direction: column;
    }

    .hero-ctas .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
