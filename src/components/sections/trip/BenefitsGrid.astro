---
interface BenefitItem {
  icon: string;
  text: string;
}

interface Props {
  benefits: BenefitItem[];
}

const { benefits } = Astro.props;

const mid = Math.ceil(benefits.length / 2);
const leftCol = benefits.slice(0, mid);
const rightCol = benefits.slice(mid);
---

<section
  class="section"
  style="background: var(--color-paper);"
  aria-labelledby="benefits-heading"
>
  <div class="container">
    <div class="benefits-header">
      <p class="eyebrow">YANG KAMU DAPATKAN</p>
      <h2 id="benefits-heading" class="section-title">
        Yang Akan Kamu Dapatkan dari <span class="italic">JAGATRIP</span>
      </h2>
    </div>

    <div class="benefits-grid" role="list" aria-label="Daftar manfaat program JAGATRIP">
      <div class="benefits-col">
        {leftCol.map((benefit) => (
          <div class="benefit-item" role="listitem">
            <span class="benefit-icon" aria-hidden="true" style="font-size: 30px;">{benefit.icon}</span>
            <p class="benefit-text">{benefit.text}</p>
          </div>
        ))}
      </div>
      <div class="benefits-col">
        {rightCol.map((benefit) => (
          <div class="benefit-item" role="listitem">
            <span class="benefit-icon" aria-hidden="true" style="font-size: 30px;">{benefit.icon}</span>
            <p class="benefit-text">{benefit.text}</p>
          </div>
        ))}
      </div>
    </div>

    <blockquote class="pull-quote benefits-quote">
      "Perjalanan ini bukan pengeluaran. Ini adalah INVESTASI terbaik untuk sekolah dan generasi yang kamu didik."
    </blockquote>
  </div>
</section>

<style>
  .benefits-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .benefits-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .benefit-item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: var(--color-white);
    border-radius: 12px;
    padding: 16px;
    border: 1px solid var(--color-grey-light);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .benefit-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-testi-hover);
  }

  .benefit-icon {
    flex-shrink: 0;
    line-height: 1;
    margin-top: 2px;
  }

  .benefit-text {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0;
  }

  .benefits-quote {
    max-width: 700px;
    margin-inline: auto;
  }

  @media (max-width: 640px) {
    .benefits-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
