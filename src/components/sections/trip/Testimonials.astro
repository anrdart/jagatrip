---
interface TestimonialItem {
  id: string;
  name: string;
  role: string;
  quote: string;
  avatar?: string;
  avatarGradient?: string;
  rating: number;
}

interface Props {
  testimonials: TestimonialItem[];
}

const { testimonials } = Astro.props;
---

<section
  class="section"
  style="background: var(--color-white);"
  aria-labelledby="testimonials-heading"
>
  <div class="container">
    <div class="testi-header">
      <p class="eyebrow">TESTIMONI ALUMNI</p>
      <h2 id="testimonials-heading" class="section-title">
        Kata Mereka yang <span class="italic">Sudah Ikut JAGATRIP</span>
      </h2>
      <p class="testi-sub">
        Ribuan praktisi pendidikan Indonesia telah merasakan manfaatnya. Ini cerita mereka.
      </p>
    </div>

    {testimonials.length > 0 ? (
      <ul class="testi-grid" role="list" aria-label="Testimoni peserta JAGATRIP">
        {testimonials.map((t) => {
          const stars = '★'.repeat(t.rating) + '☆'.repeat(5 - t.rating);
          const gradientVar = t.avatarGradient ? `var(${t.avatarGradient})` : 'var(--color-grad-avatar-1)';
          return (
            <li class="testi-card" role="listitem">
              <div class="testi-stars" aria-label={`Rating: ${t.rating} dari 5 bintang`}>
                <span class="stars" aria-hidden="true">{stars}</span>
              </div>

              <blockquote class="testi-quote">
                "{t.quote}"
              </blockquote>

              <div class="testi-author">
                <div
                  class="testi-avatar"
                  style={`background: ${gradientVar};`}
                  aria-hidden="true"
                >
                  {t.avatar ?? t.name.charAt(0)}
                </div>
                <div class="testi-author-info">
                  <p class="testi-name">{t.name}</p>
                  <p class="testi-role">{t.role}</p>
                </div>
              </div>
            </li>
          );
        })}
      </ul>
    ) : (
      <div class="testi-empty">
        <p>
          Program ini segera hadir! Jadilah yang pertama merasakan JAGATRIP dan berbagi pengalaman dengan ribuan pendidik Indonesia.
        </p>
      </div>
    )}

    <!-- Social proof row -->
    <div class="testi-social-proof">
      <div class="avatar-stack" aria-hidden="true">
        <div class="avatar" style="background: var(--color-grad-avatar-1);">BH</div>
        <div class="avatar" style="background: var(--color-grad-avatar-3);">SR</div>
        <div class="avatar" style="background: var(--color-grad-avatar-2);">AF</div>
        <div class="avatar" style="background: var(--color-grad-avatar-4);">+</div>
      </div>
      <p class="social-proof-label">
        <strong>100+</strong> praktisi pendidikan telah bergabung dengan JAGATRIP
      </p>
    </div>
  </div>
</section>

<style>
  .testi-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .testi-sub {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-grey);
    margin-top: 16px;
    max-width: 560px;
    margin-inline: auto;
  }

  .testi-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 48px 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .testi-stars {
    margin-bottom: 16px;
  }

  .testi-quote {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-ink);
    margin: 0 0 24px 0;
    flex: 1;
  }

  .testi-author {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 1px solid var(--color-grey-light);
  }

  .testi-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 14px;
    color: white;
    flex-shrink: 0;
  }

  .testi-author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testi-name {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-ink);
    margin: 0;
  }

  .testi-role {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey);
    margin: 0;
  }

  .testi-card {
    display: flex;
    flex-direction: column;
  }

  .testi-empty {
    max-width: 560px;
    margin-inline: auto;
    text-align: center;
    padding: 48px;
    background: var(--color-paper);
    border-radius: var(--radius-card);
  }

  .testi-empty p {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-grey);
    margin: 0;
  }

  /* Social proof */
  .testi-social-proof {
    display: flex;
    align-items: center;
    gap: 16px;
    justify-content: center;
  }

  .social-proof-label {
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--color-grey);
    margin: 0;
  }

  .social-proof-label strong {
    color: var(--color-orange);
  }

  @media (max-width: 968px) {
    .testi-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .testi-grid {
      grid-template-columns: 1fr;
    }

    .testi-social-proof {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
