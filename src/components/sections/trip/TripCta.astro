---
import { waLink, SITE } from '../../../data/site';

interface Props {
  destination: string;
  dateRange: string;
  slug: string;
}

const { destination, dateRange, slug } = Astro.props;

const waHref = waLink(destination, dateRange);
---

<section
  class="section glow-orange-center"
  style="background: var(--color-ink); position: relative; overflow: hidden;"
  aria-labelledby="trip-cta-heading"
>
  <div class="container">
    <div class="cta-inner">
      <p class="eyebrow" style="color: var(--color-orange);">DAFTAR SEKARANG</p>

      <h2 id="trip-cta-heading" class="section-title cta-title">
        Siap Ubah <span class="italic" style="color: var(--color-orange);">Cara Pandangmu?</span>
      </h2>

      <p class="cta-trip">
        JAGATRIP to {destination} — <time>{dateRange}</time>
      </p>

      <p class="cta-lead">
        Kursi terbatas. Jangan sampai kamu menyesal ketinggalan.
      </p>

      <div class="cta-buttons">
        <a
          href={waHref}
          class="btn btn-wa btn-lg"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Daftar JAGATRIP to ${destination} via WhatsApp ${SITE.waDisplay}`}
        >
          Daftar via WhatsApp <span aria-hidden="true">💬</span> {SITE.waDisplay}
        </a>

        <a
          href="/"
          class="btn btn-secondary btn-lg cta-back-btn"
        >
          Kembali ke Beranda
        </a>
      </div>

      <p class="cta-reassurance">
        <span aria-hidden="true">🔒</span> Informasi kamu aman · Tidak ada spam · Tim kami siap membantu
      </p>
    </div>
  </div>
</section>

<style>
  .cta-inner {
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 1;
  }

  .cta-title {
    color: var(--color-white);
  }

  .cta-trip {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    font-style: italic;
    color: var(--color-orange);
    margin: 0;
  }

  .cta-lead {
    font-family: var(--font-body);
    font-size: 17px;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    max-width: 480px;
  }

  .cta-buttons {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }

  .cta-back-btn {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .cta-back-btn:hover {
    border-color: var(--color-white);
    color: var(--color-white);
    background: rgba(255, 255, 255, 0.05);
  }

  .cta-reassurance {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
    margin-top: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 580px) {
    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-buttons .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
