---
import { formatDate } from '../../../lib/format';

interface ItineraryDay {
  day: number;
  date: Date;
  dayName: string;
  theme: string;
  activities: string[];
}

interface Props {
  itinerary: ItineraryDay[];
  destination: string;
}

const { itinerary, destination } = Astro.props;

const durationDays = itinerary.length;
let gridClass = 'itinerary-grid-single';
if (durationDays >= 5 && durationDays < 7) {
  gridClass = 'itinerary-grid-two';
} else if (durationDays >= 7) {
  gridClass = 'itinerary-grid-wrap';
}
---

<section
  class="section"
  style="background: var(--color-white);"
  aria-labelledby="itinerary-heading"
>
  <div class="container">
    <div class="itinerary-header-section">
      <p class="eyebrow">ITINERARY</p>
      <h2 id="itinerary" class="section-title">
        {itinerary.length} Hari yang Bisa Mengubah <span class="italic">5 Tahun ke Depan Sekolahmu</span>
      </h2>
      <p class="itinerary-sub">
        Setiap hari dirancang dengan cermat untuk memberikan pengalaman belajar maksimal di {destination}.
      </p>
    </div>

    <div class={`itinerary-days ${gridClass}`} role="list" aria-label={`Itinerary ${durationDays} hari di ${destination}`}>
      {itinerary.map((day) => {
        const dateISO = day.date.toISOString().split('T')[0];
        return (
          <article class="itinerary-card" role="listitem" aria-label={`Hari ${day.day}: ${day.theme}`}>
            <div class="itinerary-header">
              <div class="itinerary-day-num" aria-label={`Hari ${day.day}`}>
                HARI {day.day}
              </div>
              <time datetime={dateISO} class="itinerary-date">
                {day.dayName}, {formatDate(day.date, { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              <p class="itinerary-theme">{day.theme}</p>
            </div>
            <div class="itinerary-body">
              {day.activities.map((activity) => (
                <div class="itinerary-activity">
                  {activity}
                </div>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    <p class="itinerary-note">
      <span aria-hidden="true">📌</span>
      Itinerary dapat berubah sewaktu-waktu menyesuaikan kondisi lapangan. Perubahan akan dikonfirmasi kepada peserta yang sudah mendaftar.
    </p>
  </div>
</section>

<style>
  .itinerary-header-section {
    text-align: center;
    margin-bottom: 56px;
  }

  .itinerary-sub {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-grey);
    margin-top: 16px;
    max-width: 600px;
    margin-inline: auto;
  }

  .itinerary-days {
    margin-bottom: 32px;
  }

  /* Layout variants */
  .itinerary-grid-single {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    max-width: 720px;
    margin-inline: auto;
  }

  .itinerary-grid-two {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .itinerary-grid-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
  }

  .itinerary-grid-wrap .itinerary-card {
    flex: 1 1 320px;
  }

  /* Day number styling */
  .itinerary-date {
    display: block;
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(255,255,255,0.7);
    margin-top: 4px;
    margin-bottom: 8px;
  }

  .itinerary-theme {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-orange);
    margin: 0;
  }

  .itinerary-note {
    text-align: center;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--color-grey);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 16px 24px;
    background: var(--color-paper);
    border-radius: var(--radius-input);
    max-width: 720px;
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .itinerary-grid-two {
      grid-template-columns: 1fr;
    }

    .itinerary-grid-wrap .itinerary-card {
      flex: 1 1 100%;
    }
  }
</style>
