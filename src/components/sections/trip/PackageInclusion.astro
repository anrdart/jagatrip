---
interface InclusionItem {
  icon: string;
  label: string;
  desc: string;
}

interface Props {
  inclusions: InclusionItem[];
}

const { inclusions } = Astro.props;
---

<section
  class="section"
  style="background: var(--color-paper);"
  aria-labelledby="inclusion-heading"
>
  <div class="container">
    <div class="inclusion-header">
      <p class="eyebrow">YANG TERMASUK PAKET</p>
      <h2 id="inclusion-heading" class="section-title">
        Perjalanan Edukasi Sudah <span class="italic">Termasuk Semua</span>
      </h2>
      <p class="inclusion-sub">
        Bayar sekali, nikmati semua. Tidak ada biaya tersembunyi — semua sudah termasuk dalam paket.
      </p>
    </div>

    <ul class="inclusion-grid" role="list" aria-label="Daftar yang termasuk dalam paket">
      {inclusions.map((item) => (
        <li class="inclusion-item" role="listitem">
          <div class="inclusion-icon" aria-hidden="true">{item.icon}</div>
          <div class="inclusion-content">
            <p class="inclusion-label">{item.label}</p>
            <p class="inclusion-desc">{item.desc}</p>
          </div>
        </li>
      ))}
    </ul>

    <div class="inclusion-note">
      <p>
        <strong>Tidak termasuk:</strong> pengeluaran pribadi, oleh-oleh, visa (jika diperlukan), bagasi tambahan, dan tips pemandu lokal.
      </p>
    </div>
  </div>
</section>

<style>
  .inclusion-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .inclusion-sub {
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--color-grey);
    margin-top: 16px;
    max-width: 560px;
    margin-inline: auto;
  }

  .inclusion-grid {
    list-style: none;
    padding: 0;
    margin: 0 0 32px 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .inclusion-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .inclusion-note {
    background: var(--color-white);
    border: 1px solid var(--color-grey-light);
    border-radius: var(--radius-input);
    padding: 16px 24px;
    max-width: 720px;
    margin-inline: auto;
    text-align: center;
  }

  .inclusion-note p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-grey);
    margin: 0;
  }

  .inclusion-note strong {
    color: var(--color-ink);
  }

  @media (max-width: 968px) {
    .inclusion-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 580px) {
    .inclusion-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
