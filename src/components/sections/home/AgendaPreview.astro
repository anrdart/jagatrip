---
import { getCollection } from 'astro:content';

const allTrips = await getCollection('trips');
const trips = allTrips.sort((a, b) => a.data.monthNum - b.data.monthNum);
---

<section
  id="agenda"
  class="section"
  style="background: var(--color-paper);"
  aria-labelledby="agenda-title"
>
  <div class="container">
    <!-- Header -->
    <div style="text-align: center; max-width: 720px; margin-inline: auto; margin-bottom: 64px;">
      <span class="eyebrow">AGENDA 2026</span>
      <h2 id="agenda-title" class="section-title">
        7 Destinasi, <span class="italic">7 Pengalaman Tak Terlupakan.</span>
      </h2>
    </div>

    <!-- Trip cards grid -->
    <div class="trips-grid">
      {trips.map((trip) => (
        <a
          href={`/trips/${trip.data.slug}`}
          class="dest-card reveal"
          style={`background: var(${trip.data.gradient}); min-height: 220px;`}
          aria-label={`${trip.data.destination} — ${trip.data.month} ${trip.data.year}`}
        >
          <div class="dest-card-content">
            <!-- Flag -->
            <p style="font-size: 32px; margin-bottom: 8px; line-height: 1;" aria-hidden="true">
              {trip.data.flag}
            </p>

            <!-- Category badge -->
            <span style="
              display: inline-block;
              font-family: var(--font-mono);
              font-size: 9px;
              font-weight: 700;
              letter-spacing: 2px;
              text-transform: uppercase;
              padding: 4px 10px;
              border-radius: 100px;
              background: rgba(255,255,255,0.2);
              color: rgba(255,255,255,0.9);
              margin-bottom: 8px;
            ">
              {trip.data.category}
            </span>

            <!-- Destination name -->
            <h3 style="
              font-family: var(--font-display);
              font-size: 20px;
              font-weight: 700;
              color: white;
              margin-bottom: 4px;
              line-height: 1.2;
            ">
              {trip.data.destination}
            </h3>

            <!-- Duration -->
            <p style="
              font-family: var(--font-body);
              font-size: 13px;
              color: rgba(255,255,255,0.8);
              margin-bottom: 6px;
            ">
              {trip.data.duration}
            </p>

            <!-- Month + Year -->
            <p style="
              font-family: var(--font-mono);
              font-size: 11px;
              font-weight: 700;
              letter-spacing: 2px;
              text-transform: uppercase;
              color: rgba(255,255,255,0.7);
              margin-bottom: 14px;
            ">
              {trip.data.month} {trip.data.year}
            </p>

            <!-- CTA -->
            <span style="
              display: inline-flex;
              align-items: center;
              gap: 6px;
              font-family: var(--font-body);
              font-size: 13px;
              font-weight: 700;
              color: white;
              background: rgba(255,255,255,0.2);
              padding: 8px 16px;
              border-radius: 100px;
              backdrop-filter: blur(4px);
              transition: background 0.2s;
            ">
              Lihat Detail →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .trips-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .dest-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  @media (max-width: 968px) {
    .trips-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .trips-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
