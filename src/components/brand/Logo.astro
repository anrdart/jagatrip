---
interface Props {
  variant?: 'horizontal' | 'icon' | 'wordmark' | 'stacked';
  height?:  number;
  class?:   string;
}
const { variant = 'horizontal', height = 40, class: cls = '' } = Astro.props;

const src = {
  horizontal: '/images/logo-horizontal.png',
  icon:       '/images/logo-icon.png',
  wordmark:   '/images/logo-wordmark.png',
  stacked:    '/images/logo-stacked.png',
}[variant];

const alt = {
  horizontal: 'JAGATRIP — Edu-Tourism Premium untuk Praktisi Pendidikan',
  icon:       'JAGATRIP logo icon',
  wordmark:   'jagatrip wordmark',
  stacked:    'PT JAGATRIP MITRA EDUKASI',
}[variant];
---
<img
  src={src}
  alt={alt}
  height={height}
  width={variant === 'icon' ? height : undefined}
  style={`height:${height}px; width:auto;`}
  class={cls}
  loading="eager"
  decoding="async"
/>
