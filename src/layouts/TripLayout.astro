---
import BaseLayout from './BaseLayout.astro';
import { SITE }   from '../data/site';
import { tripEventSchema }  from '../data/schemas/tripEvent';
import { faqPageSchema }    from '../data/schemas/faqPage';
import { breadcrumbSchema } from '../data/schemas/breadcrumb';

interface Props {
  slug:        string;
  title:       string;
  description: string;
  destination: string;
  dateStart:   Date;
  dateEnd:     Date;
  price?:      number;
  status:      'open' | 'limited' | 'soldout' | 'tba';
  faqs?:       { q: string; a: string }[];
}

const { slug, title, description, destination, dateStart, dateEnd, price, status, faqs = [] } = Astro.props;

const extraSchemas = [
  tripEventSchema({ slug, name: title, description, startDate: dateStart, endDate: dateEnd, location: destination, price, status }),
  breadcrumbSchema([{ name: 'Program', url: `${SITE.url}/#agenda` }, { name: destination, url: `${SITE.url}/trips/${slug}` }]),
  ...(faqs.length > 0 ? [faqPageSchema(faqs.map(f => ({ question: f.q, answer: f.a })))] : []),
];
---
<BaseLayout
  title={title}
  description={description}
  ogImage={`${SITE.url}/images/og-${slug}.png`}
  ogType="event"
  extraSchemas={extraSchemas}
>
  <slot />
</BaseLayout>
